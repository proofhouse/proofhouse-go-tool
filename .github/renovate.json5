{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // This repo's Renovate config is mostly shared org policy, pulled in from
  // the two presets in proofhouse/github-actions:
  //
  //   - renovate-global-config.json5 via globalExtends — the global-only
  //     identity, rate limits, and requireConfig (resolved at global-config
  //     time, the only scope where those options take effect).
  //   - renovate-config.json5 via extends — the repository-level rules plus
  //     the Justfile and Vale custom managers shared by every repo.
  //
  // Only the Go-module specifics stay inline below: they don't apply to the
  // non-Go repos, so they don't belong in the shared preset. packageRules
  // is a mergeable array, so the go-deps rule appends to the preset's rules.
  globalExtends: [
    "github>proofhouse/github-actions//.github/renovate-global-config.json5",
  ],
  extends: [
    "github>proofhouse/github-actions//.github/renovate-config.json5",
  ],

  // Single-repo scope. The one global-only option that can't move to the
  // shared preset — it differs per repo.
  repositories: ["proofhouse/proofhouse-go"],

  // `gomodTidy` runs `go mod tidy` after a Go-module update so go.sum and
  // the indirect graph stay coherent in the same PR. Self-hosting means the
  // project picks the Go toolchain version the sidecar uses (matches
  // go.mod's toolchain pin, not whatever the hosted Mend App ships).
  postUpdateOptions: ["gomodTidy"],

  packageRules: [
    // One review surface for every Go-module bump. Bundling avoids the
    // "twelve tiny PRs" failure mode and makes the vendor/ diff easier to
    // read as a single unit.
    {
      groupName: "go-deps",
      matchManagers: ["gomod"],
    },
  ],
}
