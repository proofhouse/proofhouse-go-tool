# Local development
tmp/
.env
.env.*
!.env.example
mise.local.toml

# Agent commit-message draft. Authored at the repo root so vale's
# [formats] mapping resolves it, linted via `just lint-commit-msg`,
# then consumed with `git commit -F COMMIT_AGENTMSG`. Never committed.
COMMIT_AGENTMSG

# Go build output
bin/
/proofhouse-go
coverage.out
coverage.html
coverage.txt
coverage.xml
coverage.covdata*/

# Test outputs
testdata/fuzz/

# Linter caches
.rumdl_cache/
node_modules/
.cspell-cache

# goreleaser
dist/

# gremlins
.gremlins/
gremlins-report.json

# Claude Code
.claude/worktrees/
.claude/settings.local.json

# Vale synced packages (keep vocabulary and project styles).
# Each negation needs the parent un-ignored first — git can't re-include
# a child whose ancestor directory stays excluded.
.vale/*
!.vale/proofhouse/
!.vale/config/
.vale/config/*
!.vale/config/vocabularies/
.vale/config/vocabularies/*
!.vale/config/vocabularies/proofhouse/

# macOS
.DS_Store
